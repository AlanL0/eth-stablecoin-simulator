# Copy to .env.local (frontend) or service-specific .env files — never commit real values.
# Planning docs with full variable lists are local-only (gitignored /docs/).

# --- Frontend (Vercel / local) ---
NEXT_PUBLIC_JAVA_API_URL=http://localhost:8080
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000
# Supabase: Project URL from Dashboard → Connect (or Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Prefer 2026 publishable key (sb_publishable_...). Legacy anon JWT still works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Java service ---
PORT=8080
ETH_RPC_URL=
# Supabase migrations / Java+Python persistence — secret or service_role connection only (never NEXT_PUBLIC_*)
# Or set SUPABASE_DB_PASSWORD (project DB password from dashboard) and run: make setup-supabase-db
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
DATABASE_URL=
REDIS_URL=
ALLOWED_ORIGINS=http://localhost:3000
# Quote required — CoinGecko URL contains & which breaks plain `source .env`
PUBLIC_PRICE_API_URL="https://api.coingecko.com/api/v3/simple/price?ids=ethereum&vs_currencies=usd"
STATIC_ETH_PRICE_USD=3800

# --- Python agent ---
JAVA_API_URL=http://localhost:8080
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
MODEL_PRIMARY=
MODEL_FALLBACK=
MODEL_SAFETY=
LLM_DAILY_FREE_CALL_CAP=200
CHART_REQUEST_ESCALATION_THRESHOLD=3
INTERNAL_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000
# Set true only behind a trusted reverse proxy (rate-limit client IP from X-Forwarded-For)
TRUST_PROXY_HEADERS=false