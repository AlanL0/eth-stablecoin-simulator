{
  "openapi": "3.0.3",
  "info": {
    "title": "ETH Stablecoin Java Service",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/api/simulations": {
      "post": {
        "operationId": "runSimulation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SimulationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Simulation result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SimulationResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/price/eth": {
      "get": {
        "operationId": "getEthPrice",
        "responses": {
          "200": {
            "description": "ETH price quote",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EthPriceResponse" }
              }
            }
          }
        }
      }
    },
    "/api/yields": {
      "get": {
        "operationId": "getYields",
        "parameters": [
          {
            "name": "asset",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Yield snapshots",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/YieldSnapshotResponse" }
              }
            }
          }
        }
      }
    },
    "/api/charts/simulation-projection": {
      "get": {
        "operationId": "chartSimulationProjection",
        "parameters": [{ "$ref": "#/components/parameters/ChartQueryParams" }],
        "responses": {
          "200": {
            "description": "Chart spec",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChartSpecV1" }
              }
            }
          }
        }
      }
    },
    "/api/charts/liquidation-band": {
      "get": {
        "operationId": "chartLiquidationBand",
        "parameters": [{ "$ref": "#/components/parameters/ChartQueryParams" }],
        "responses": {
          "200": {
            "description": "Chart spec",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChartSpecV1" }
              }
            }
          }
        }
      }
    },
    "/api/charts/health-ratio": {
      "get": {
        "operationId": "chartHealthRatio",
        "parameters": [{ "$ref": "#/components/parameters/ChartQueryParams" }],
        "responses": {
          "200": {
            "description": "Chart spec",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChartSpecV1" }
              }
            }
          }
        }
      }
    },
    "/api/wallet/{address}/stablecoins": {
      "get": {
        "operationId": "getWalletStablecoins",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Stablecoin balances",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WalletStablecoinsResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid address",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/audit/{address}": {
      "get": {
        "operationId": "getAudit",
        "parameters": [
          { "name": "address", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "from", "in": "query", "schema": { "type": "string" } },
          { "name": "to", "in": "query", "schema": { "type": "string" } },
          { "name": "token", "in": "query", "schema": { "type": "string" } },
          { "name": "hideValues", "in": "query", "schema": { "type": "boolean", "default": false } }
        ],
        "responses": {
          "200": {
            "description": "Audit events",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuditResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid address",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "ChartQueryParams": {
        "name": "chartQuery",
        "in": "query",
        "style": "form",
        "explode": true,
        "schema": { "$ref": "#/components/schemas/ChartQueryParams" }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "service": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": { "type": "array", "items": { "type": "string" } }
        }
      },
      "SimulationRequest": {
        "type": "object",
        "required": ["protocol"],
        "properties": {
          "ethAmount": { "type": "number" },
          "collateralUsd": { "type": "number" },
          "ethPriceUsd": { "type": "number" },
          "protocol": { "type": "string" },
          "targetCollateralRatio": { "type": "number" },
          "liquidationRatio": { "type": "number" },
          "stabilityFeePct": { "type": "number" },
          "deployYieldPct": { "type": "number", "default": 5 },
          "years": { "type": "integer", "default": 1 },
          "compoundsPerYear": { "type": "integer", "default": 12 },
          "treasuryContextEnabled": { "type": "boolean", "default": true },
          "stablecoinReserveModel": { "type": "string", "default": "usdc_style" },
          "reserveInTreasuriesPct": { "type": "number" },
          "tbillApyPct": { "type": "number" },
          "systemSupplyUsd": { "type": "number" }
        }
      },
      "SimulationResponse": {
        "type": "object",
        "required": [
          "collateralValueUsd",
          "stablecoinDebtUsd",
          "liquidationPriceUsd",
          "healthRatio",
          "riskTier",
          "assumptions",
          "charts"
        ],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "collateralValueUsd": { "type": "number" },
          "stablecoinDebtUsd": { "type": "number" },
          "liquidationPriceUsd": { "type": "number" },
          "annualStabilityFeeUsd": { "type": "number" },
          "projectedGrossYieldUsd": { "type": "number" },
          "projectedNetYieldUsd": { "type": "number" },
          "healthRatio": { "type": "number" },
          "riskTier": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "assumptions": { "$ref": "#/components/schemas/SimulationAssumptions" },
          "treasuryContext": { "$ref": "#/components/schemas/TreasuryContext" },
          "charts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ChartSpecV1" }
          }
        }
      },
      "SimulationAssumptions": {
        "type": "object",
        "properties": {
          "protocol": { "type": "string" },
          "ethAmount": { "type": "number" },
          "ethPriceUsd": { "type": "number" },
          "ethPriceSource": { "type": "string" },
          "targetCollateralRatio": { "type": "number" },
          "liquidationRatio": { "type": "number" },
          "stabilityFeePct": { "type": "number" },
          "deployYieldPct": { "type": "number" },
          "years": { "type": "integer" },
          "compoundsPerYear": { "type": "integer" },
          "stabilityFeeModel": { "type": "string" }
        }
      },
      "TreasuryContext": {
        "type": "object",
        "properties": {
          "disclaimer": { "type": "string" },
          "yourMintUsd": { "type": "number" },
          "assumptions": { "type": "object", "additionalProperties": true },
          "yourMint": {
            "type": "object",
            "properties": {
              "impliedTreasuryBackingUsd": { "type": "number" },
              "annualIssuerReserveYieldUsd": { "type": "number" },
              "projectedIssuerReserveYieldUsd": { "type": "number" }
            }
          },
          "systemContext": {
            "type": "object",
            "properties": {
              "impliedTreasuryBackingUsd": { "type": "number" },
              "annualIssuerReserveYieldUsd": { "type": "number" },
              "treasuryDemandProxyUsd": { "type": "number" }
            }
          },
          "personalComparison": {
            "type": "object",
            "properties": {
              "yourDeFiProjectedNetYieldUsd": { "type": "number" },
              "note": { "type": "string" }
            }
          }
        }
      },
      "EthPriceResponse": {
        "type": "object",
        "properties": {
          "priceUsd": { "type": "number" },
          "source": { "type": "string" },
          "observedAt": { "type": "string" },
          "stale": { "type": "boolean" },
          "degraded": { "type": "boolean" }
        }
      },
      "YieldSnapshotResponse": {
        "type": "object",
        "properties": {
          "asset": { "type": "string" },
          "yields": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/YieldQuote" }
          }
        }
      },
      "YieldQuote": {
        "type": "object",
        "properties": {
          "protocol": { "type": "string" },
          "apyPct": { "type": "number" },
          "source": { "type": "string" },
          "riskTier": { "type": "string" },
          "observedAt": { "type": "string" }
        }
      },
      "ChartQueryParams": {
        "type": "object",
        "properties": {
          "ethAmount": { "type": "number" },
          "ethPriceUsd": { "type": "number" },
          "protocol": { "type": "string" },
          "targetCollateralRatio": { "type": "number" },
          "liquidationRatio": { "type": "number" },
          "stabilityFeePct": { "type": "number" },
          "deployYieldPct": { "type": "number" },
          "years": { "type": "integer" },
          "compoundsPerYear": { "type": "integer" }
        }
      },
      "ChartSpecV1": {
        "type": "object",
        "required": [
          "schemaVersion",
          "chartId",
          "chartType",
          "title",
          "xAxis",
          "yAxis",
          "series",
          "source",
          "generatedAt"
        ],
        "properties": {
          "schemaVersion": { "type": "string", "enum": ["1.0"] },
          "chartId": { "type": "string" },
          "chartType": {
            "type": "string",
            "enum": ["line", "area", "band", "bar", "composed"]
          },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "xAxis": { "$ref": "#/components/schemas/ChartAxis" },
          "yAxis": { "$ref": "#/components/schemas/ChartAxis" },
          "series": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ChartSeries" }
          },
          "annotations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ChartAnnotation" }
          },
          "legend": { "$ref": "#/components/schemas/ChartLegend" },
          "meta": { "$ref": "#/components/schemas/ChartMeta" },
          "source": { "type": "string" },
          "generatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ChartAxis": {
        "type": "object",
        "required": ["type", "label"],
        "properties": {
          "type": { "type": "string", "enum": ["linear", "time", "category"] },
          "label": { "type": "string" },
          "unit": { "type": "string" },
          "format": {
            "type": "string",
            "enum": ["number", "usd", "percent", "eth", "month_index"]
          },
          "domain": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
          "tickCount": { "type": "integer" }
        }
      },
      "ChartSeries": {
        "type": "object",
        "required": ["id", "name", "geometry", "points"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "geometry": { "type": "string", "enum": ["line", "area", "band", "bar"] },
          "points": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ChartPoint" }
          },
          "style": { "$ref": "#/components/schemas/ChartSeriesStyle" }
        }
      },
      "ChartPoint": {
        "type": "object",
        "required": ["x"],
        "properties": {
          "x": {},
          "y": { "type": "number" },
          "y0": { "type": "number" },
          "y1": { "type": "number" },
          "label": { "type": "string" }
        }
      },
      "ChartSeriesStyle": {
        "type": "object",
        "properties": {
          "colorToken": {
            "type": "string",
            "enum": ["primary", "secondary", "positive", "negative", "warning", "neutral"]
          },
          "strokeDash": { "type": "string", "enum": ["solid", "dashed", "dotted"] },
          "fillOpacity": { "type": "number" }
        }
      },
      "ChartAnnotation": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["horizontal_line", "vertical_line", "band", "point", "label"]
          },
          "axis": { "type": "string", "enum": ["x", "y"] },
          "value": {},
          "valueEnd": {},
          "label": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "low", "medium", "high"] }
        }
      },
      "ChartLegend": {
        "type": "object",
        "properties": {
          "position": { "type": "string", "enum": ["top", "bottom", "right", "hidden"] },
          "show": { "type": "boolean" }
        }
      },
      "ChartMeta": {
        "type": "object",
        "properties": {
          "simulationId": { "type": "string", "format": "uuid" },
          "protocol": { "type": "string" },
          "ethPriceUsd": { "type": "number" },
          "ethAmount": { "type": "number" },
          "stablecoinDebtUsd": { "type": "number" },
          "sources": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ChartSource" }
          }
        }
      },
      "ChartSource": {
        "type": "object",
        "required": ["field", "source", "observedAt"],
        "properties": {
          "field": { "type": "string" },
          "source": { "type": "string" },
          "observedAt": { "type": "string" },
          "stale": { "type": "boolean" }
        }
      },
      "WalletStablecoinsResponse": {
        "type": "object",
        "properties": {
          "address": { "type": "string" },
          "balances": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/StablecoinBalance" }
          },
          "source": { "type": "string" },
          "observedAt": { "type": "string" },
          "assumptions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "StablecoinBalance": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "contractAddress": { "type": "string" },
          "decimals": { "type": "integer" },
          "balance": { "type": "string" },
          "balanceUsd": { "type": "number" }
        }
      },
      "AuditResponse": {
        "type": "object",
        "properties": {
          "address": { "type": "string" },
          "events": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AuditEvent" }
          },
          "hideValues": { "type": "boolean" },
          "assumptions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "AuditEvent": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "txHash": { "type": "string" },
          "logIndex": { "type": "integer" },
          "fromAddress": { "type": "string" },
          "toAddress": { "type": "string" },
          "amount": { "type": "string" },
          "blockNumber": { "type": "integer", "format": "int64" },
          "occurredAt": { "type": "string" }
        }
      }
    }
  }
}